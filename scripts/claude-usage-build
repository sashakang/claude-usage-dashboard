#!/bin/bash
# Rebuild Claude Usage Dashboard from JSONL data + template
# Read-only on the JSONL — rotation is handled by claude-usage-log
# Can be run standalone (after template edits) or called by claude-usage-log

set -euo pipefail

# Resolve symlinks to find the real script location (works when symlinked or copied)
PROJ_DIR="$(python3 -c "
import os, sys
script = os.path.realpath(sys.argv[1])
print(os.path.dirname(os.path.dirname(script)))
" "$0" 2>/dev/null)" || PROJ_DIR=""

# Fallback: search common locations for template.html
if [ ! -f "$PROJ_DIR/template.html" ]; then
  for d in "$HOME/claude-usage-dashboard" "$HOME/Projects/claude-usage-dashboard"; do
    if [ -f "$d/template.html" ]; then PROJ_DIR="$d"; break; fi
  done
fi

LOG_FILE="${1:-$HOME/.claude/projects/claude-usage-dashboard/claude-usage.jsonl}"
TEMPLATE="$PROJ_DIR/template.html"
DASHBOARD="$PROJ_DIR/index.html"

if [ ! -f "$TEMPLATE" ]; then
  echo "error: template not found: $TEMPLATE" >&2
  exit 1
fi

if [ ! -f "$LOG_FILE" ]; then
  echo "error: data file not found: $LOG_FILE" >&2
  exit 1
fi

python3 - "$LOG_FILE" "$TEMPLATE" "$DASHBOARD" <<'PYEOF'
import json, sys, os, tempfile
from datetime import datetime, timezone, timedelta

log_file, template_file, dashboard_file = sys.argv[1], sys.argv[2], sys.argv[3]
cutoff = (datetime.now(timezone.utc) - timedelta(days=35)).isoformat()

lines = open(log_file).read().strip().split('\n')
records = []
skipped = 0
for l in lines:
    try:
        r = json.loads(l)
        if 'error' in r:
            continue
        if r.get('seven_day') is None and r.get('five_hour') is None and r.get('codex_seven_day') is None and r.get('codex_five_hour') is None:
            continue
        # Migrate old records: split codex_* fields into separate record
        if 'service' not in r:
            r['service'] = 'claude'
            r['account'] = r.get('account', 'default')
            if r.get('codex_five_hour') is not None or r.get('codex_seven_day') is not None:
                cx = {'ts': r['ts'], 'service': 'codex', 'account': 'default',
                      'five_hour': r.pop('codex_five_hour', None),
                      'five_hour_resets': r.pop('codex_five_hour_resets', None),
                      'seven_day': r.pop('codex_seven_day', None),
                      'seven_day_resets': r.pop('codex_seven_day_resets', None)}
                records.append(cx)
        if r.get('ts', '') >= cutoff:
            records.append(r)
    except:
        skipped += 1

if skipped:
    print(f'warning: skipped {skipped} unparseable lines', file=sys.stderr)

if not records:
    print('warning: no valid records in data file', file=sys.stderr)

data_json = json.dumps(records, separators=(',',':'))
template = open(template_file).read()

if '__DATA_PLACEHOLDER__' not in template:
    print('error: __DATA_PLACEHOLDER__ not found in template', file=sys.stderr)
    sys.exit(1)

html = template.replace('__DATA_PLACEHOLDER__', data_json)

# Inject version from git tag
import subprocess
try:
    version = subprocess.check_output(
        ['git', 'describe', '--tags', '--abbrev=0'],
        cwd=os.path.dirname(template_file), stderr=subprocess.DEVNULL
    ).decode().strip()
except Exception:
    version = ''
html = html.replace('__VERSION_PLACEHOLDER__', version)

# Atomic write for dashboard
fd, tmp = tempfile.mkstemp(dir=os.path.dirname(dashboard_file), suffix='.tmp')
try:
    with os.fdopen(fd, 'w') as f:
        f.write(html)
    os.rename(tmp, dashboard_file)
except:
    os.unlink(tmp)
    raise

print(f'Built dashboard: {len(records)} records → {dashboard_file}')
PYEOF
